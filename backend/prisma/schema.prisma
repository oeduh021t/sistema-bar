generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model bares {
  id              Int               @id @default(autoincrement())
  nome            String            @db.VarChar(100) // Nome ou Razão Social
  cnpj            String?           @db.VarChar(18)  // Sem o @unique para testar livremente
  status          String            @default("ATIVO") @db.VarChar(20) // "ATIVO" ou "BLOQUEADO"
  data_vencimento DateTime?         @db.Timestamp(6) // 🟢 Controla o vencimento da assinatura SaaS
  criado_em       DateTime?         @default(now()) @db.Timestamp(6)
  
  // Relações existentes mantidas intocadas
  clientes_fiado  clientes_fiado[]
  historico_fiado historico_fiado[]
  mesas           mesas[]
  pedidos_mesa    pedidos_mesa[]
  produtos        produtos[]
  usuarios        usuarios[]
  mensalidades    mensalidades[]    // 🟢 Histórico financeiro de mensalidades do bar
}

model clientes_fiado {
  id              Int               @id @default(autoincrement())
  bar_id          Int?
  nome            String            @db.VarChar(100)
  telefone        String?           @db.VarChar(20)
  limite_credito  Decimal           @default(200.00) @db.Decimal(10, 2)
  saldo_devedor   Decimal           @default(0.00) @db.Decimal(10, 2)
  bares           bares?            @relation(fields: [bar_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  historico_fiado historico_fiado[]
}

model produtos {
  id                 Int            @id @default(autoincrement())
  bar_id             Int?
  nome               String         @db.VarChar(100)
  preco_venda        Decimal        @db.Decimal(10, 2)
  quantidade_estoque Int            @default(0)
  codigo_barras      String?        @db.VarChar(50)
  pedidos_mesa       pedidos_mesa[]
  bares              bares?         @relation(fields: [bar_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bar_produto")
}

model historico_fiado {
  id              Int            @id @default(autoincrement())
  bar_id          Int?
  cliente_id      Int?
  tipo            String         @db.VarChar(10)
  valor           Decimal        @db.Decimal(10, 2)
  descricao       String?        @db.VarChar(255)
  criado_em       DateTime?      @default(now()) @db.Timestamp(6)
  bares           bares?         @relation(fields: [bar_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  clientes_fiado clientes_fiado? @relation(fields: [cliente_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model mesas {
  id           Int            @id @default(autoincrement())
  bar_id       Int?
  numero       Int
  status       String         @default("LIVRE") @db.VarChar(20)
  bares        bares?         @relation(fields: [bar_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pedidos_mesa pedidos_mesa[]

  @@unique([bar_id, numero], map: "unique_mesa_por_bar")
}

model pedidos_mesa {
  id         Int       @id @default(autoincrement())
  bar_id     Int?
  mesa_id    Int?
  produto_id Int?
  quantidade Int       @default(1)
  criado_em  DateTime? @default(now()) @db.Timestamp(6)
  bares      bares?    @relation(fields: [bar_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  mesas      mesas?    @relation(fields: [mesa_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  produtos   produtos? @relation(fields: [produto_id], references: [id], onDelete: Restrict, onUpdate: NoAction)
}

model usuarios {
  id        Int       @id @default(autoincrement())
  bar_id    Int?
  nome      String    @db.VarChar(100)
  email     String    @unique @db.VarChar(100)
  senha     String    @db.VarChar(255)
  funcao    String    @default("GARCOM") @db.VarChar(20)
  status    String    @default("ATIVO") @db.VarChar(20) // 🟢 ATIVO ou INATIVO (evita deleção física)
  criado_em DateTime? @default(now()) @db.Timestamp(6)
  bares     bares?    @relation(fields: [bar_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model Caixas {
  id                     Int       @id @default(autoincrement())
  bar_id                 Int
  usuario_id             Int
  valor_abertura         Decimal   @db.Decimal(10, 2)
  total_dinheiro_sistema Decimal   @default(0.00) @db.Decimal(10, 2)
  total_pix_sistema      Decimal   @default(0.00) @db.Decimal(10, 2)
  total_cartao_sistema   Decimal   @default(0.00) @db.Decimal(10, 2)
  valor_fechamento_real  Decimal?  @db.Decimal(10, 2)
  diferenca_caixa        Decimal?  @db.Decimal(10, 2)
  status                 String    @default("ABERTO")
  data_abertura          DateTime  @default(now())
  data_fechamento        DateTime?

  @@index([bar_id])
}

model Movimentacoes_caixa {
  id         Int      @id @default(autoincrement())
  bar_id     Int
  caixa_id   Int
  tipo       String   
  meio_pagto String   
  valor      Decimal  @db.Decimal(10, 2)
  descricao  String?
  data       DateTime @default(now())

  @@index([caixa_id])
}

model Saas_admins {
  id          Int      @id @default(autoincrement())
  nome        String
  email       String   @unique
  senha       String
  data_criacao DateTime @default(now())
}

// 🟢 Nova tabela para controle financeiro e histórico de assinaturas do SaaS
model mensalidades {
  id                 Int      @id @default(autoincrement())
  bar_id             Int
  valor_pago         Decimal  @db.Decimal(10, 2)
  data_pagamento     DateTime @default(now()) @db.Timestamp(6)
  proximo_vencimento DateTime @db.Timestamp(6)
  status             String   @default("PAGO") @db.VarChar(20)
  bares              bares    @relation(fields: [bar_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}